{
  "name": "@neogebra/desktop",
  "version": "1.0.0",
  "description": "Neogebra — a desktop manager that installs a lightweight plugin framework into GeoGebra and manages each install's plugins.",
  "license": "MIT",
  "author": "唐晓翼 <tangxy97@hotmail.com>",
  "homepage": "https://github.com/tangxiaoyi97/ngb-loader",
  "private": true,
  "main": "src/main.js",
  "scripts": {
    "build:renderer": "node renderer/build.mjs",
    "prepack:assets": "node scripts/prepack.mjs",
    "start": "electron .",
    "pack": "npm run build:renderer && npm run prepack:assets && electron-builder --dir",
    "dist": "npm run build:renderer && npm run prepack:assets && electron-builder"
  },
  "dependencies": {
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.21.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "build": {
    "appId": "org.neogebra.loader",
    "productName": "Neogebra Loader",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "src/**/*",
      "renderer/dist/**/*",
      "vendor/**/*",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "vendor/proxy-core",
        "to": "proxy-core"
      }
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "hardenedRuntime": false,
      "identity": null
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Development"
    }
  }
}
