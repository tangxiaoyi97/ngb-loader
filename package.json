{
  "name": "neogebra",
  "version": "2.0.0-beta",
  "private": true,
  "description": "Neogebra — a lightweight, non-invasive plugin framework for the GeoGebra desktop app. A desktop manager injects a proxy layer that loads plugins dynamically at startup, without modifying GeoGebra's own code.",
  "license": "MIT",
  "homepage": "https://github.com/tangxiaoyi97/ngb-loader",
  "workspaces": [
    "packages/injector-core",
    "packages/installer",
    "packages/proxy-core",
    "packages/sdk",
    "packages/panel",
    "packages/desktop",
    "examples/hello-plugin",
    "examples/container-playground"
  ],
  "scripts": {
    "test": "node scripts/run-tests.mjs",
    "test:e2e": "node tests/e2e/run-e2e.mjs",
    "sync-version": "node scripts/sync-version.mjs",
    "build:proxy": "node scripts/sync-version.mjs && node scripts/build-proxy.mjs",
    "installer": "npm --workspace @neogebra/installer run start",
    "cli": "node packages/injector-core/bin/ggb-extend.js",
    "doctor": "node scripts/doctor.mjs",
    "dev:install": "node scripts/dev-install.mjs",
    "clean": "node scripts/clean.mjs",
    "reset-user-data": "node scripts/reset-user-data.mjs",
    "build": "npm run build:proxy",
    "build:desktop": "npm run build:proxy && npm --workspace @neogebra/desktop run build:renderer",
    "desktop": "npm run build:proxy && npm --workspace @neogebra/desktop run build:renderer && npm --workspace @neogebra/desktop run start",
    "test:e2e:real": "node tests/e2e/run-real-ggb.mjs"
  },
  "engines": {
    "node": "^22.13.0 || >=24.0.0"
  },
  "devDependencies": {
    "jsdom": "^29.1.1",
    "playwright-core": "^1.60.0"
  }
}